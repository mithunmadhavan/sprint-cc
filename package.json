{
  "name": "sprint-cc",
  "version": "1.0.0",
  "private": true,
  "description": "Sprint Planner monorepo orchestrator",
  "main": "src/apps/ey-sprint-business-services/dist/main.js",
  "scripts": {
    "start": "npm --prefix src/apps/ey-sprint-business-services run start",
    "dev": "npm --prefix src/apps/ey-sprint-business-services run start:dev",
    "test": "npm --prefix src/apps/ey-sprint-business-services run test",
    "start:backend:new": "npm --prefix src/apps/ey-sprint-business-services run start",
    "dev:backend:new": "npm --prefix src/apps/ey-sprint-business-services run start:dev",
    "start:frontend:new": "npm --prefix src/apps/ey-sprint-frontend run start",
    "dev:frontend:new": "npm --prefix src/apps/ey-sprint-frontend run dev",
    "test:e2e:new": "npm --prefix src/apps/ey-sprint-business-services run test:e2e -- --runInBand",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "engines": {
    "node": ">=20"
  }
}
